# Google OAuth 2.0 credentials (Web application client) — read at build time by Vite.
# Copy to .env (gitignored) and fill in. The OAuth client must be type
# "Web application" with http://localhost as an authorized redirect URI.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# Microsoft (Teams / Graph) OAuth — read at build time by Vite. The app
# registration must be type "Mobile and desktop applications" (public client,
# PKCE — no client secret) with http://localhost as a redirect URI. Delegated
# permissions: Chat.Read, User.Read, offline_access, openid, profile, email.
#
# IMPORTANT: reading Teams chat messages via Graph is only supported for
# work/school (Entra org) accounts, NOT personal Microsoft accounts. Set
# VITE_MS_TENANT to your organization/tenant ID (not "common"/"consumers").
VITE_MS_CLIENT_ID=
VITE_MS_TENANT=

# NOTE: The Anthropic API key is NOT set here. It is entered in the app's
# Settings panel and stored locally (settings.json), never committed.
